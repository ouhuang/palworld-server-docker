# ==============================
# 容器与服务器基础配置
# ==============================

# 容器内使用的时区。
TZ=UTC
# 服务器最大玩家数。
PLAYERS=16
# 游戏服务器监听端口（UDP）。
PORT=8211
# 容器内运行 steam 用户的 UID。
PUID=1000
# 容器内运行 steam 用户的 GID。
PGID=1000
# 多线程优化；通常保持 false，CPU 核心较多时可尝试 true。
MULTITHREADING=false
# 是否显示在 Palworld 社区服务器列表；开启时建议同时设置 SERVER_PASSWORD。
COMMUNITY=false
# 社区服务器对外显示的公网 IP；留空则自动检测。
PUBLIC_IP=
# 社区服务器对外显示的公网端口；留空则自动检测，不改变游戏监听端口。
PUBLIC_PORT=
# 服务器名称。
SERVER_NAME=palworld-server-docker by Thijs van Loef
# 服务器描述。
SERVER_DESCRIPTION=palworld-server-docker by Thijs van Loef
# 进入服务器所需的密码；留空表示无密码。
SERVER_PASSWORD=worldofpals
# 管理员密码；也用于部分 RCON/REST API 管理操作。
ADMIN_PASSWORD=adminPasswordHere
# 容器启动时是否检查并更新/安装 Palworld；首次启动保持 true，安装完成后建议改为 false。
UPDATE_ON_BOOT=true
# 是否启用 RCON。
RCON_ENABLED=false
# RCON 监听端口。
RCON_PORT=25575
# Steam 查询端口（UDP），用于社区服务器查询。
QUERY_PORT=27015
# 是否启用自动备份。
BACKUP_ENABLED=true
# 是否删除过期备份。
DELETE_OLD_BACKUPS=false
# 备份保留天数；DELETE_OLD_BACKUPS=true 时生效。
OLD_BACKUP_DAYS=30
# 自动备份 Cron 表达式。
BACKUP_CRON_EXPRESSION=0 0 * * *
# 是否启用定时自动更新；需要 RCON_ENABLED=true 和 UPDATE_ON_BOOT=true。
AUTO_UPDATE_ENABLED=false
# 自动更新 Cron 表达式。
AUTO_UPDATE_CRON_EXPRESSION=0 * * * *
# 自动更新前提前提醒的分钟数。
AUTO_UPDATE_WARN_MINUTES=30
# 是否启用自动重启。
AUTO_REBOOT_ENABLED=false
# 即使有玩家在线也是否强制重启。
AUTO_REBOOT_EVEN_IF_PLAYERS_ONLINE=false
# 自动重启前提前提醒的分钟数。
AUTO_REBOOT_WARN_MINUTES=5
# 自动重启 Cron 表达式。
AUTO_REBOOT_CRON_EXPRESSION=0 0 * * *

# ==============================
# 自动暂停、日志与配置生成
# ==============================

# 是否在没有玩家时自动暂停服务器进程。
AUTO_PAUSE_ENABLED=false
# 最后一个玩家离线后等待多少秒再暂停。
AUTO_PAUSE_TIMEOUT_EST=180
# 是否输出自动暂停日志。
AUTO_PAUSE_LOG=true
# 是否启用自动暂停调试日志。
AUTO_PAUSE_DEBUG=false
# 是否记录玩家加入/离开事件。
ENABLE_PLAYER_LOGGING=true
# 玩家日志轮询间隔（秒）。
PLAYER_LOGGING_POLL_PERIOD=5
# 是否过滤并整理服务器日志。
LOG_FILTER_ENABLED=true
# 官方服务器日志格式使用 Text 或 Json；日志整理脚本还兼容 default、logfmt、plain、colored。
LOG_FORMAT_TYPE=Text
# 是否让启动脚本根据环境变量重新生成 PalWorldSettings.ini；通常保持 false。
DISABLE_GENERATE_SETTINGS=false

# ==============================
# Palworld 世界与游戏平衡配置
# ==============================

# 游戏难度；None 表示使用默认难度。
DIFFICULTY=None
# 野生 Pal 等级随机模式：None、Region 或 All。
RANDOMIZER_TYPE=
# 野生 Pal 随机模式使用的种子。
RANDOMIZER_SEED=none
# 是否完全随机化野生 Pal 等级；false 为按区域范围随机。
IS_RANDOMIZER_PAL_LEVEL_RANDOM=False
# 白天流速倍率；1 为默认。
DAYTIME_SPEEDRATE=1.000000
# 夜晚流速倍率；1 为默认。
NIGHTTIME_SPEEDRATE=1.000000
# 经验获得倍率。
EXP_RATE=1.000000
# Pal 捕获倍率。
PAL_CAPTURE_RATE=1.000000
# Pal 刷新数量倍率；提高可能增加性能压力。
PAL_SPAWN_NUM_RATE=1.000000
# Pal 造成伤害倍率。
PAL_DAMAGE_RATE_ATTACK=1.000000
# Pal 承受伤害倍率。
PAL_DAMAGE_RATE_DEFENSE=1.000000
# 玩家造成伤害倍率。
PLAYER_DAMAGE_RATE_ATTACK=1.000000
# 玩家承受伤害倍率。
PLAYER_DAMAGE_RATE_DEFENSE=1.000000
# 玩家饥饿下降倍率；小于 1 代表下降更慢。
PLAYER_STOMACH_DECREASE_RATE=1.000000
# 玩家体力消耗倍率；小于 1 代表消耗更慢。
PLAYER_STAMINA_DECREASE_RATE=1.000000
# 玩家自然回血倍率。
PLAYER_AUTO_HP_REGEN_RATE=1.000000
# 玩家睡眠/在床回血倍率。
PLAYER_AUTO_HP_REGEN_RATE_IN_SLEEP=1.000000
# Pal 饥饿下降倍率；小于 1 代表下降更慢。
PAL_STOMACH_DECREASE_RATE=1.000000
# Pal 体力消耗倍率；小于 1 代表消耗更慢。
PAL_STAMINA_DECREASE_RATE=1.000000
# Pal 自然回血倍率。
PAL_AUTO_HP_REGEN_RATE=1.000000
# Pal 睡眠/在 Palbox 中回血倍率。
PAL_AUTO_HP_REGEN_RATE_IN_SLEEP=1.000000
# 建筑生命值倍率。
BUILD_OBJECT_HP_RATE=1.000000
# 建筑受到伤害倍率。
BUILD_OBJECT_DAMAGE_RATE=1.000000
# 建筑自然损坏倍率；小于 1 代表损坏更慢。
BUILD_OBJECT_DETERIORATION_DAMAGE_RATE=1.000000
# 采集物品数量倍率。
COLLECTION_DROP_RATE=1.000000
# 采集点生命值倍率。
COLLECTION_OBJECT_HP_RATE=1.000000
# 采集点刷新间隔倍率；小于 1 代表刷新更快。
COLLECTION_OBJECT_RESPAWN_SPEED_RATE=1.000000
# 敌人掉落物数量倍率。
ENEMY_DROP_ITEM_RATE=1.000000
# 死亡惩罚：None 不掉落，Item 掉普通物品，ItemAndEquipment 掉物品和装备，All 还会掉队伍 Pal。
DEATH_PENALTY=Item
# 是否允许玩家互相伤害。
ENABLE_PLAYER_TO_PLAYER_DAMAGE=False
# 是否开启友伤。
ENABLE_FRIENDLY_FIRE=False
# 是否启用入侵敌人。
ENABLE_INVADER_ENEMY=True
# 是否启用 Unko 相关掉落。
ACTIVE_UNKO=False
# 是否启用手柄瞄准辅助。
ENABLE_AIM_ASSIST_PAD=True
# 是否启用键鼠瞄准辅助。
ENABLE_AIM_ASSIST_KEYBOARD=False
# 世界中允许存在的普通掉落物上限。
DROP_ITEM_MAX_NUM=3000
# 世界中允许存在的 Unko 掉落物上限。
DROP_ITEM_MAX_NUM_UNKO=100
# 服务器总基地数量上限。
BASE_CAMP_MAX_NUM=128
# 每个基地最多工作的 Pal 数量。
BASE_CAMP_WORKER_MAX_NUM=15
# 掉落物在地面上保留的小时数。
DROP_ITEM_ALIVE_MAX_HOURS=1.000000
# 无公会成员在线时是否自动删除该公会建筑和基地 Pal。
AUTO_RESET_GUILD_NO_ONLINE_PLAYERS=False
# 公会无人在线多久后自动清理（小时）。
AUTO_RESET_GUILD_TIME_NO_ONLINE_PLAYERS=72.00000
# 每个公会最大玩家数。
GUILD_PLAYER_MAX_NUM=20
# 每个公会最多拥有的基地数。
BASE_CAMP_MAX_NUM_IN_GUILD=4
# 最大蛋孵化时间（小时）；其他蛋会按比例缩短。
PAL_EGG_DEFAULT_HATCHING_TIME=1.000000
# 基地工作速度倍率。
WORK_SPEED_RATE=1.000000
# 自动保存间隔（秒）。
AUTO_SAVE_SPAN=30.000000
# 是否启用多人模式标记。
IS_MULTIPLAY=False
# 是否启用 PvP。
IS_PVP=False
# 是否启用 Hardcore；死亡后不能正常重生。
HARDCORE=False
# Hardcore 模式死亡后是否允许重建角色。
CHARACTER_RECREATE_IN_HARDCORE=False
# 是否死亡永久丢失 Pal。
PAL_LOST=False
# 是否可以拾取其他公会的死亡掉落物。
CAN_PICKUP_OTHER_GUILD_DEATH_PENALTY_DROP=False
# 是否启用未登录惩罚。
ENABLE_NON_LOGIN_PENALTY=True
# 是否启用快速旅行。
ENABLE_FAST_TRAVEL=True
# 是否允许在地图上选择出生位置。
IS_START_LOCATION_SELECT_BY_MAP=False
# 玩家退出后是否留在原地进入睡眠状态。
EXIST_PLAYER_AFTER_LOGOUT=False
# 是否允许其他公会玩家防御基地。
ENABLE_DEFENSE_OTHER_GUILD_PLAYER=False
# 是否显示其他公会基地范围特效。
INVISIBLE_OTHER_GUILD_BASE_CAMP_AREA_FX=False
# 是否限制靠近传送点等结构的位置建造。
BUILD_AREA_LIMIT=False
# 物品重量倍率；小于 1 代表物品更轻。
ITEM_WEIGHT_RATE=1.000000
# 联机合作最大玩家数。
COOP_PLAYER_MAX_NUM=4
# 服务器区域标识。
REGION=
# 是否启用身份验证。
USEAUTH=True
# Ban 列表地址。
BAN_LIST_URL=https://b.palworldgame.com/api/banlist.txt
# 是否启用 REST API。
REST_API_ENABLED=True
# REST API 端口。
REST_API_PORT=8212
# 是否在 ESC 菜单显示玩家列表。
SHOW_PLAYER_LIST=False
# 每分钟最多聊天消息数。
CHAT_POST_LIMIT_PER_MINUTE=30
# 是否启用 Predator Boss Pal。
ENABLE_PREDATOR_BOSS_PAL=True
# 每名玩家建筑数量上限；0 表示不限制。
MAX_BUILDING_LIMIT_NUM=0
# Pal 同步距离（厘米）；提高可能增加性能压力。
SERVER_REPLICATE_PAWN_CULL_DISTANCE=15000.000000
# 兼容保留项：当前镜像模板未写入该字段，通常不会生效。
SERVER_REPLICATE_PAWN_CULL_DISTANCE_IN_BASE_CAMP=5000.000000
# 允许连接的平台列表。
CROSSPLAY_PLATFORMS=(Steam,Xbox,PS5,Mac)
# 是否使用备份存档机制。
USE_BACKUP_SAVE_DATA=True
# 陨石/补给箱事件间隔（分钟）。
SUPPLY_DROP_SPAN=60
# 是否使用 DepotDownloader 安装/更新服务器。
USE_DEPOT_DOWNLOADER=False
# 是否安装 Insider 测试版本。
INSTALL_BETA_INSIDER=False
# 是否允许导出到 Global Palbox。
ALLOW_GLOBAL_PALBOX_EXPORT=True
# 是否允许从 Global Palbox 导入。
ALLOW_GLOBAL_PALBOX_IMPORT=False
# 装备耐久损耗倍率。
EQUIPMENT_DURABILITY_DAMAGE_RATE=1.000000
# 容器界面打开时强制同步间隔（秒）。
ITEM_CONTAINER_FORCE_MARK_DIRTY_INTERVAL=1.000000
# 物品腐败速度倍率。
ITEM_CORRUPTION_MULTIPLIER=1.000000

# ==============================
# Palworld 1.0+ 新增/扩展配置
# ==============================

# 允许使用物理效果的掉落物数量上限；-1 表示不限制。
PHYSICS_ACTIVE_DROP_ITEM_MAX_NUM=-1
# 是否允许客户端使用 Mod。
ALLOW_CLIENT_MOD=True
# Pal 数据存储检查间隔（秒）。
PLAYER_DATA_PAL_STORAGE_UPDATE_CHECK_TICK_INTERVAL=1.000000
# 是否显示玩家加入/离开消息。
IS_SHOW_JOIN_LEFT_MESSAGE=True
# 放牧生产速度倍率。
MONSTER_FARM_ACTION_SPEED_RATE=1.000000
# 禁用的科技列表；留空表示不禁用。
DENY_TECHNOLOGY_LIST=
# 公会重新加入冷却时间（分钟）。
GUILD_REJOIN_COOLDOWN_MINUTES=0
# 公会会长转移检查间隔（秒）。
AUTO_TRANSFER_MASTER_CHECK_INTERVAL_SECONDS=3600.000000
# 会长长期不活跃多少天后触发转移。
AUTO_TRANSFER_MASTER_THRESHOLD_DAYS=14
# 每帧最多处理的公会数。
MAX_GUILDS_PER_FRAME=10
# 死亡后再次重生的基础冷却时间（秒）。
BLOCK_RESPAWN_TIME=5.000000
# 生存时间达到多少秒后，下一次死亡应用额外重生惩罚。
RESPAWN_PENALTY_DURATION_THRESHOLD=0.000000
# 额外重生冷却倍率。
RESPAWN_PENALTY_TIME_SCALE=2.000000
# 是否在地图基地标记上显示 PvP 专属物品数量。
DISPLAY_PVP_ITEM_NUM_ON_WORLD_MAP_BASE_CAMP=False
# 是否在地图玩家标记上显示 PvP 专属物品数量。
DISPLAY_PVP_ITEM_NUM_ON_WORLD_MAP_PLAYER=False
# PvP 击杀时额外掉落的物品类型。
ADDITIONAL_DROP_ITEM_WHEN_PLAYER_KILLING_IN_PVP_MODE=PlayerDropItem
# PvP 击杀时额外掉落的数量。
ADDITIONAL_DROP_ITEM_NUM_WHEN_PLAYER_KILLING_IN_PVP_MODE=1
# 是否启用 PvP 击杀额外掉落。
ADDITIONAL_DROP_ITEM_WHEN_PLAYER_KILLING_IN_PVP_MODE_ENABLED=False
# 是否启用游戏内语音。
ENABLE_VOICE_CHAT=False
# 语音开始衰减的距离。
VOICE_CHAT_MAX_VOLUME_DISTANCE=3000.000000
# 语音音量降为 0 的距离。
VOICE_CHAT_ZERO_VOLUME_DISTANCE=15000.000000
# 是否允许给生命值属性加点。
ALLOW_ENHANCE_STAT_HEALTH=True
# 是否允许给攻击属性加点。
ALLOW_ENHANCE_STAT_ATTACK=True
# 是否允许给体力属性加点。
ALLOW_ENHANCE_STAT_STAMINA=True
# 是否允许给负重属性加点。
ALLOW_ENHANCE_STAT_WEIGHT=True
# 是否允许给工作速度属性加点。
ALLOW_ENHANCE_STAT_WORK_SPEED=True
# 是否在建筑上显示创建者玩家 UID。
ENABLE_BUILDING_PLAYER_UID_DISPLAY=False
# 建筑名称显示缓存时间（秒）。
BUILDING_NAME_DISPLAY_CACHE_TTL_SECONDS=60

# ==============================
# Box64 配置（仅 ARM64 主机相关）
# ==============================

# 发生崩溃时可调整以下参数；一般保持默认。
BOX64_DYNAREC_STRONGMEM=1 # 可设为 2 或 3；3 稳定性更好但性能更差。
BOX64_DYNAREC_BIGBLOCK=1 # 可设为 0；稳定性更好但性能更差。
BOX64_DYNAREC_SAFEFLAGS=1 # 可设为 2；稳定性更好但性能更差。
BOX64_DYNAREC_FASTROUND=1 # 可设为 0；稳定性更好但性能更差。
BOX64_DYNAREC_FASTNAN=1 # 可设为 0；稳定性更好但性能更差。
BOX64_DYNAREC_X87DOUBLE=0 # 可设为 1；稳定性更好但性能更差。
